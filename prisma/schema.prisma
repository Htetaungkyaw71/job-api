generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String
  location     String
  isRemote     Boolean       @default(false)
  salaryMin    Int?
  salaryMax    Int?
  techStack    String[]
  level        JobLevel
  type         JobType
  createdAt    DateTime      @default(now())
  expiresAt    DateTime?
  companyId    String
  postedById   String
  externalJob  Boolean       @default(false)
  applyLink    String?
  logo         String?
  salary       String?
  company_name String?
  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id])
  postedBy     User          @relation("PostedJobs", fields: [postedById], references: [id])

  @@index([expiresAt])
  @@index([createdAt(sort: Desc)])
  @@index([level])
  @@index([type])
  @@index([salaryMin])
}

model Application {
  id        String            @id @default(uuid())
  status    ApplicationStatus @default(APPLIED)
  createdAt DateTime          @default(now())
  jobId     String
  userId    String
  name      String?
  email     String?
  cv_url    String?
  updatedAt DateTime          @updatedAt
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  role               Role                @default(CANDIDATE)
  createdAt          DateTime            @default(now())
  isEmailVerified    Boolean             @default(false)
  applications       Application[]
  candidateProfile   CandidateProfile?
  company            Company?
  jobsPosted         Job[]               @relation("PostedJobs")
  recruiterProfile   RecruiterProfile?
  verificationTokens VerificationToken[]
}

model VerificationToken {
  id        String           @id @default(uuid())
  email     String
  code      String           @unique
  type      VerificationType
  isUsed    Boolean          @default(false)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
}

model CandidateProfile {
  id             String            @id @default(uuid())
  headline       String?
  description    String?
  location       String?
  openToRemote   Boolean           @default(true)
  availability   Availability
  jobStatus      JobStatus
  visibility     ProfileVisibility @default(RECRUITERS_ONLY)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userId         String            @unique
  expectedSalary Int?
  cvUrl          String?
  fullName       String
  cvFilename     String?
  user           User              @relation(fields: [userId], references: [id])
  experiences    Experience[]
  languages      Language[]
  skills         Skill[]
}

model RecruiterProfile {
  id          String   @id @default(uuid())
  fullName    String
  title       String
  email       String
  phone       String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
  userId      String   @unique
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Skill {
  id        String           @id @default(uuid())
  name      String
  level     SkillLevel
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id])
}

model Language {
  id        String           @id @default(uuid())
  name      String
  level     LanguageLevel
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id])
}

model Experience {
  id          String           @id @default(uuid())
  companyName String
  role        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id])
}

model Company {
  id           String             @id @default(uuid())
  name         String
  description  String
  website      String?
  industry     String
  size         CompanySize
  foundedYear  Int?
  location     String
  hiringStatus HiringStatus
  verified     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  ownerId      String             @unique
  owner        User               @relation(fields: [ownerId], references: [id])
  jobs         Job[]
  recruiters   RecruiterProfile[]
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum VerificationType {
  SIGNUP_VERIFICATION
  PASSWORD_RESET
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum Availability {
  IMMEDIATE
  TWO_WEEKS
  ONE_MONTH
  NEGOTIABLE
}

enum JobStatus {
  ACTIVELY_LOOKING
  OPEN_TO_OFFERS
  NOT_LOOKING
}

enum ProfileVisibility {
  PUBLIC
  RECRUITERS_ONLY
  PRIVATE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageLevel {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum HiringStatus {
  ACTIVELY_HIRING
  LIMITED_HIRING
  NOT_HIRING
}

enum JobLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}
